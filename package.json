{
  "name": "localbeam-desktop",
  "version": "1.0.0",
  "description": "LocalBeam desktop app (Electron + Node backend)",
  "main": "electron/main.js",
  "author": {
    "name": "Vaibhav Makvana",
    "email": "hello@vaibhavmakvana.in"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dist": "electron-builder -mwl",
    "dist:win": "electron-builder --win nsis",
    "dist:linux": "electron-builder --linux AppImage deb",
    "dist:mac": "electron-builder --mac dmg"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.localbeam.desktop",
    "productName": "LocalBeam",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "package.json",
      "!server/node_modules/**/*",
      "!**/*.map"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "maintainer": "Vaibhav <vaibhav@example.com>",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.utilities"
    }
  }
}
